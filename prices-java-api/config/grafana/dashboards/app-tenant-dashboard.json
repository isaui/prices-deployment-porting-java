            "targets": [
                {
                    "expr": "sum(traefik_service_open_connections{job=\"traefik\", service=~\"backend-${service}@docker\"})",
                    "legendFormat": "Backend"
                },
                {
                    "expr": "sum(traefik_service_open_connections{job=\"traefik\", service=~\"frontend-${service}@docker\"})",
                    "legendFormat": "Frontend"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        },
