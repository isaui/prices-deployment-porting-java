            "collapsed": false,
            "id": 200
        },
        {
            "type": "bargauge",
            "title": "Container Uptime",
            "gridPos": {
                "h": 6,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "id": 201,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "time() - docker_started_time{containerName=~\".*$service.*\"}",
                    "legendFormat": "{{containerName}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                }
            },
            "options": {
                "displayMode": "gradient",
                "orientation": "horizontal",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "showUnfilled": true,
                "minVizHeight": 16,
                "minVizWidth": 8
            }
        },
        {
            "type": "stat",
            "title": "DB Size",
            "gridPos": {
                "h": 3,
                "w": 3,
                "x": 12,
                "y": 1
            },
            "id": 203,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "pg_database_size_bytes{job=\"postgres-exporter\", datname=~\"${service}_db\"}",
                    "legendFormat": "Size"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes"
                }
            }
        },
        {
            "type": "stat",
            "title": "DB Connections",
            "gridPos": {
                "h": 3,
                "w": 3,
                "x": 15,
                "y": 1
            },
            "id": 204,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(pg_stat_activity_count{job=\"postgres-exporter\", state=\"active\", datname=~\"${service}_db\"})",
                    "legendFormat": "Active"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 20
                            },
                            {
                                "color": "red",
                                "value": 50
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "Cache Hit %",
            "gridPos": {
                "h": 3,
                "w": 3,
                "x": 18,
                "y": 1
            },
            "id": 205,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "pg_stat_database_blks_hit{job=\"postgres-exporter\", datname=~\"${service}_db\"} / (pg_stat_database_blks_hit{job=\"postgres-exporter\", datname=~\"${service}_db\"} + pg_stat_database_blks_read{job=\"postgres-exporter\", datname=~\"${service}_db\"}) * 100",
                    "legendFormat": "Hit %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 90
                            },
                            {
                                "color": "green",
                                "value": 99
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "DB Locks",
            "gridPos": {
                "h": 3,
                "w": 3,
                "x": 21,
                "y": 1
            },
            "id": 206,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(pg_locks_count{job=\"postgres-exporter\", datname=~\"${service}_db\"})",
                    "legendFormat": "Locks"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 20
                            },
                            {
                                "color": "red",
                                "value": 50
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "DB TPS",
            "gridPos": {
                "h": 3,
                "w": 3,
                "x": 12,
                "y": 4
            },
            "id": 207,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "rate(pg_stat_database_xact_commit{job=\"postgres-exporter\", datname=~\"${service}_db\"}[$__rate_interval])",
                    "legendFormat": "TPS"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ops"
                }
            }
        },
        {
            "type": "timeseries",
            "title": "Traefik Open Connections",
            "gridPos": {
