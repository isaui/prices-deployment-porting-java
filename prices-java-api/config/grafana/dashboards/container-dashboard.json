{
    "annotations": {
        "list": []
    },
    "description": "Docker container monitoring powered by Logporter",
    "editable": true,
    "graphTooltip": 1,
    "schemaVersion": 39,
    "tags": [
        "monitoring",
        "container",
        "logporter",
        "Docker"
    ],
    "templating": {
        "list": [
            {
                "current": {},
                "definition": "label_values(docker_cpu_usage_total, containerName)",
                "includeAll": true,
                "multi": true,
                "name": "ContainerName",
                "query": {
                    "query": "label_values(docker_cpu_usage_total, containerName)"
                },
                "refresh": 2,
                "allValue": ".*",
                "type": "query"
            },
            {
                "current": {},
                "definition": "label_values(docker_cpu_usage_total, hostname)",
                "includeAll": true,
                "multi": true,
                "name": "HostName",
                "query": {
                    "query": "label_values(docker_cpu_usage_total, hostname)"
                },
                "refresh": 2,
                "allValue": ".*",
                "type": "query"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "refresh": "5s",
    "timezone": "browser",
    "title": "Container Monitoring",
    "uid": "container-monitoring",
    "panels": [
        {
            "type": "row",
            "title": "Container State",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "collapsed": false,
            "id": 200
        },
        {
            "type": "table",
            "title": "Container Status",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "id": 201,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "container_state_status{name=~\"$ContainerName\"}",
                    "legendFormat": "{{name}}",
                    "format": "table",
                    "instant": true,
                    "refId": "A"
                }
            ],
            "transformations": [
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true,
                            "__name__": true,
                            "job": true,
                            "instance": true
                        },
                        "renameByName": {
                            "name": "Container",
                            "status": "State",
                            "Value": "Running"
                        }
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {},
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "State"
                        },
                        "properties": [
                            {
                                "id": "mappings",
                                "value": [
                                    {
                                        "type": "value",
                                        "options": {
                                            "running": {
                                                "text": "RUNNING",
                                                "color": "green"
                                            }
                                        }
                                    },
                                    {
                                        "type": "value",
                                        "options": {
                                            "exited": {
                                                "text": "EXITED",
                                                "color": "red"
                                            }
                                        }
                                    },
                                    {
                                        "type": "value",
                                        "options": {
                                            "paused": {
                                                "text": "PAUSED",
                                                "color": "yellow"
                                            }
                                        }
                                    },
                                    {
                                        "type": "value",
                                        "options": {
                                            "created": {
                                                "text": "CREATED",
                                                "color": "blue"
                                            }
                                        }
                                    },
                                    {
                                        "type": "value",
                                        "options": {
                                            "dead": {
                                                "text": "DEAD",
                                                "color": "red"
                                            }
                                        }
                                    }
                                ]
                            },
                            {
                                "id": "custom.displayMode",
                                "value": "color-background"
                            }
                        ]
                    }
                ]
            },
            "options": {
                "showHeader": true,
                "sortBy": [
                    {
                        "displayName": "Container",
                        "desc": false
                    }
                ]
            }
        },
        {
            "type": "table",
            "title": "Health & Restarts",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "id": 202,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "container_restartcount{name=~\"$ContainerName\"}",
                    "legendFormat": "{{name}}",
                    "format": "table",
                    "instant": true,
                    "refId": "A"
                },
                {
                    "expr": "container_state_health_status{name=~\"$ContainerName\"}",
                    "legendFormat": "{{name}}",
                    "format": "table",
                    "instant": true,
                    "refId": "B"
                }
            ],
            "transformations": [
                {
                    "id": "merge",
                    "options": {}
                },
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true,
                            "__name__": true,
                            "job": true,
                            "instance": true
                        },
                        "renameByName": {
                            "name": "Container",
                            "Value #A": "Restarts",
                            "Value #B": "Health"
                        }
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {},
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Restarts"
                        },
                        "properties": [
                            {
                                "id": "thresholds",
                                "value": {
                                    "mode": "absolute",
                                    "steps": [
                                        {
                                            "color": "green",
                                            "value": null
                                        },
                                        {
                                            "color": "yellow",
                                            "value": 1
                                        },
                                        {
                                            "color": "red",
                                            "value": 5
                                        }
                                    ]
                                }
                            },
                            {
                                "id": "custom.displayMode",
                                "value": "color-background"
                            }
                        ]
                    }
                ]
            },
            "options": {
                "showHeader": true,
                "sortBy": [
                    {
                        "displayName": "Restarts",
                        "desc": true
                    }
                ]
            }
        },
        {
            "type": "row",
            "title": "Basic Metrics",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 10
            },
            "collapsed": false,
            "id": 100
        },
        {
            "type": "bargauge",
            "title": "Uptime Containers",
            "gridPos": {
                "h": 12,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "id": 1,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "time() - docker_started_time{containerName=~\"$ContainerName\", hostname=~\"$HostName\"}",
                    "legendFormat": "{{containerName}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    },
                    "unit": "s"
                },
                "overrides": []
            },
            "options": {
                "displayMode": "gradient",
                "orientation": "horizontal",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "showUnfilled": true,
                "minVizHeight": 16,
                "minVizWidth": 8
            }
        },
        {
            "type": "stat",
            "title": "Running Containers",
            "gridPos": {
                "h": 4,
                "w": 3,
                "x": 6,
                "y": 1
