{
    "annotations": {
        "list": []
    },
    "description": "Docker container monitoring powered by cAdvisor",
    "editable": true,
    "graphTooltip": 1,
    "schemaVersion": 39,
    "tags": [
        "monitoring",
        "container",
        "cadvisor",
        "Docker"
    ],
    "templating": {
        "list": [
            {
                "current": {},
                "definition": "label_values(container_cpu_usage_seconds_total{name=~\".+\"}, name)",
                "includeAll": true,
                "multi": true,
                "name": "ContainerName",
                "query": {
                    "query": "label_values(container_cpu_usage_seconds_total{name=~\".+\"}, name)"
                },
                "refresh": 2,
                "allValue": ".+",
                "type": "query"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "refresh": "5s",
    "timezone": "browser",
    "title": "Container Monitoring",
    "uid": "container-monitoring",
    "panels": [
        {
            "type": "row",
            "title": "Basic Metrics",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "collapsed": false,
            "id": 100
        },
        {
            "type": "bargauge",
            "title": "Uptime Containers",
            "gridPos": {
                "h": 12,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "id": 1,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "time() - container_start_time_seconds{name=~\"$ContainerName\"}",
                    "legendFormat": "{{name}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    },
                    "unit": "s"
                },
                "overrides": []
            },
            "options": {
                "displayMode": "gradient",
                "orientation": "horizontal",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "showUnfilled": true,
                "minVizHeight": 16,
                "minVizWidth": 8
            }
        },
        {
            "type": "stat",
            "title": "Running Containers",
            "gridPos": {
                "h": 4,
                "w": 3,
                "x": 6,
                "y": 1
            },
            "id": 2,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "count(container_last_seen{name=~\".+\"})",
                    "legendFormat": "__auto",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "colorMode": "value",
                "graphMode": "none",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "textMode": "auto"
            }
        },
        {
            "type": "stat",
            "title": "CPU Total Usage",
            "gridPos": {
                "h": 4,
                "w": 3,
                "x": 9,
                "y": 1
