                    "expr": "rate(container_cpu_cfs_throttled_seconds_total{job=\"cadvisor\", name=~\"$container\", name!=\"\"}[5m])",
                    "legendFormat": "{{name}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        },
