        {
            "type": "timeseries",
            "title": "CPU Total Usage",
            "description": "User + Kernel = Total",
            "gridPos": {
                "h": 12,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "id": 8,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "rate(docker_cpu_usage_total{containerName=~\"$ContainerName\", hostname=~\"$HostName\"}[$__rate_interval])",
                    "legendFormat": "{{containerName}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 5,
                        "lineWidth": 2,
                        "pointSize": 1,
                        "showPoints": "auto",
                        "spanNulls": false
                    },
                    "unit": "percentunit",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 80
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "lastNotNull",
                        "min",
                        "max",
                        "mean"
                    ],
                    "displayMode": "table",
                    "placement": "right",
                    "showLegend": true,
                    "sortBy": "Max",
                    "sortDesc": true
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            }
        },
