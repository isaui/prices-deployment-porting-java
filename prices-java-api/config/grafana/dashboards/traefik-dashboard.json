            "id": 3,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(rate(traefik_service_requests_total{job=\"traefik\", service=~\"$service\", code=~\"5..\"}[5m]))",
                    "legendFormat": "5xx/s"
                }
