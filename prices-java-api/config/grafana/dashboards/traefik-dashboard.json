{
    "annotations": {
        "list": []
    },
    "editable": true,
    "graphTooltip": 1,
    "schemaVersion": 39,
    "tags": [
        "monitoring",
        "traefik",
        "reverse-proxy"
    ],
    "templating": {
        "list": [
            {
                "current": {
                    "selected": true,
                    "text": "All",
                    "value": "$__all"
                },
                "datasource": {
                    "type": "prometheus",
                    "uid": "prometheus"
                },
                "definition": "label_values(traefik_service_requests_total{job=\"traefik\"}, service)",
                "allValue": ".*",
                "includeAll": true,
                "multi": true,
                "name": "service",
                "query": {
                    "query": "label_values(traefik_service_requests_total{job=\"traefik\"}, service)"
                },
                "refresh": 2,
                "type": "query"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timezone": "browser",
    "title": "Traefik Monitoring",
    "uid": "traefik-monitoring",
    "panels": [
        {
            "type": "row",
            "title": "Overview",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "collapsed": false,
            "id": 100
        },
        {
            "type": "stat",
            "title": "Total Requests/s",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "id": 1,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(rate(traefik_service_requests_total{job=\"traefik\", service=~\"$service\"}[5m]))",
                    "legendFormat": "req/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            }
        },
        {
            "type": "stat",
            "title": "4xx Rate",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 1
            },
            "id": 2,
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(rate(traefik_service_requests_total{job=\"traefik\", service=~\"$service\", code=~\"4..\"}[5m]))",
                    "legendFormat": "4xx/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
