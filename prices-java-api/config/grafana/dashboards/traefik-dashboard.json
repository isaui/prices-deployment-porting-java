            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "d",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 14
                            },
                            {
                                "color": "green",
                                "value": 30
                            }
                        ]
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Value"
                        },
                        "properties": [
                            {
                                "id": "custom.displayMode",
